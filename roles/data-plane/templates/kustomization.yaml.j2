# Rendered by RHOSO-enablement role: data-plane
# Dataplane environment overlay — resources come from the labrepo base,
# patches live in files alongside this kustomization for auditability.
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - ../../../base/dataplane

patches:
  - path: patch-nodeset-ansible.yaml
    target:
      kind: OpenStackDataPlaneNodeSet
      name: preprovisioned-nodeset
  - path: patch-nodeset-nodes.yaml
    target:
      kind: OpenStackDataPlaneNodeSet
      name: preprovisioned-nodeset
  - path: patch-pvc-storageclass.yaml
    target:
      kind: PersistentVolumeClaim
      name: openstack-dataplane-ansible-log
